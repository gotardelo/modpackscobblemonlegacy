<Window x:Class="CobblemonLegacy.NewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Avisos"
        Width="640"
        Height="560"
        MinWidth="560"
        MinHeight="440"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Assets/launcher-icon.ico">
    <Window.Resources>
        <DropShadowEffect x:Key="PanelShadow"
                          Color="#000000"
                          BlurRadius="28"
                          ShadowDepth="8"
                          Opacity="0.78" />

        <Style x:Key="NewsButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F3FAFF" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            BorderBrush="#5A88A8BE"
            BorderThickness="1"
            Background="#F0050B11"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62" />
                <RowDefinition Height="*" />
                <RowDefinition Height="64" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#11162128" Offset="0" />
                        <GradientStop Color="#12264554" Offset="0.58" />
                        <GradientStop Color="#100B141B" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,0,10,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Avisos e Changelog"
                                   Foreground="#FFFFFF"
                                   FontFamily="{StaticResource GameDisplayFont}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="Cobblemon Legacy"
                                   Foreground="{StaticResource CyanBrush}"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </StackPanel>
                    <Button Content="X"
                            Width="34"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Padding="0"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="NewsItemsControl"
                              Margin="24,18,24,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="16,14"
                                    CornerRadius="7"
                                    BorderBrush="#345A7890"
                                    BorderThickness="1"
                                    Background="#78081118">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="#FFFFFF"
                                               FontSize="16"
                                               FontWeight="Black"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding PublishedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                               Foreground="{StaticResource CyanBrush}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Margin="0,3,0,0" />
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="#C9DCE8"
                                               FontSize="13"
                                               LineHeight="16"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="#223D536A"
                    BorderThickness="0,1,0,0"
                    Background="#F2070D12">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <Button Content="Abrir Discord"
                            Style="{StaticResource NewsButton}"
                            Click="DiscordButton_Click" />
                    <Button Content="Fechar"
                            Style="{StaticResource NewsButton}"
                            Margin="10,0,0,0"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
