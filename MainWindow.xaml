<Window x:Class="CobblemonLegacy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobblemon Legacy Launcher"
        Width="980"
        Height="552"
        MinWidth="980"
        MinHeight="552"
        MaxWidth="980"
        MaxHeight="552"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="TitleShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.9" />

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>

        <Style x:Key="LoginOptionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#F3FAFF" />
            <Setter Property="Background" Value="#4A07111B" />
            <Setter Property="BorderBrush" Value="#7F7FA6BD" />
        </Style>

        <Style x:Key="FooterLinkButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="Background" Value="#50101C2A" />
            <Setter Property="BorderBrush" Value="#577AA8C4" />
        </Style>

        <Style x:Key="LauncherProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}" />
            <Setter Property="Background" Value="#5B0A111A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#526E95"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Margin="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#15A9FF" Offset="0" />
                                        <GradientStop Color="#64E8FF" Offset="0.55" />
                                        <GradientStop Color="#A8F1FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="7"
            BorderBrush="#566472"
            BorderThickness="1"
            Background="#03070B"
            ClipToBounds="True">
        <Grid>
            <Image Source="Assets/launcher-hero.png"
                   Stretch="UniformToFill"
                   Opacity="0.88" />

            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E8000205" Offset="0" />
                        <GradientStop Color="#B9000610" Offset="0.45" />
                        <GradientStop Color="#8C061423" Offset="0.72" />
                        <GradientStop Color="#C6000207" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Height="118"
                       VerticalAlignment="Top"
                       Fill="#B9000000"
                       IsHitTestVisible="False" />
            <Rectangle Height="90"
                       VerticalAlignment="Bottom"
                       Fill="#C9000000"
                       IsHitTestVisible="False" />

            <Grid MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="90" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Height="2"
                        VerticalAlignment="Bottom"
                        Background="#0366DA" />
                <Border Grid.Row="2"
                        Height="2"
                        VerticalAlignment="Top"
                        Background="#0366DA" />

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,4,0,0">
                    <TextBlock Text="COBBLEMON"
                               Foreground="#D7D9DA"
                               FontFamily="Segoe UI Black"
                               FontSize="47"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Effect="{StaticResource TitleShadow}" />
                    <TextBlock Text="LEGACY"
                               Foreground="#F1F3F4"
                               FontFamily="Segoe UI Black"
                               FontSize="40"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,-14,0,0"
                               Effect="{StaticResource TitleShadow}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,6,8,0">
                    <Button Content="–"
                            Style="{StaticResource ChromeButton}"
                            Click="MinimizeButton_Click" />
                    <Button Content="×"
                            Style="{StaticResource ChromeButton}"
                            Click="CloseButton_Click" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="430" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1"
                            Width="430"
                            VerticalAlignment="Center"
                            Padding="18,14"
                            CornerRadius="7"
                            Background="#66050910"
                            BorderBrush="#3F6E91AF"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="24"
                                              ShadowDepth="0"
                                              Opacity="0.55" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Opções de Login"
                                       Foreground="#FFFFFF"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Effect="{StaticResource TitleShadow}" />

                            <TextBlock x:Name="AccountText"
                                       Text="Carregando..."
                                       Foreground="#C6D8E8"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Margin="0,6,0,20"
                                       Visibility="Collapsed" />

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,18,0,0"
                                    Click="MicrosoftModeButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="22"
                                          Height="22"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Rectangle Fill="#F25022" />
                                        <Rectangle Grid.Column="1" Fill="#7FBA00" />
                                        <Rectangle Grid.Row="1" Fill="#00A4EF" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="Entrar com Microsoft"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,8,0,0"
                                    Click="OfflineModeButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="23"
                                            Height="23"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="#FFFFFF"
                                            BorderThickness="2"
                                            CornerRadius="4">
                                        <TextBlock Text="+"
                                                   Foreground="#FFFFFF"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-4,0,0" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Usar nickname offline"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Grid x:Name="NicknameEditorPanel"
                                  Margin="0,14,0,0"
                                  Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="94" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NicknameTextBox"
                                         MaxLength="16"
                                         ToolTip="Nickname offline" />
                                <Button Grid.Column="2"
                                        Content="Salvar"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="SaveNicknameButton_Click" />
                            </Grid>

                            <Button x:Name="PlayButton"
                                    Content="JOGAR"
                                    Height="52"
                                    Margin="0,12,0,0"
                                    FontSize="19"
                                    FontWeight="Black"
                                    Visibility="Collapsed"
                                    Click="PlayButton_Click" />

                            <Button x:Name="UpdateButton"
                                    Content="Atualizar pack"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="36"
                                    Margin="0,8,0,0"
                                    Click="UpdateButton_Click" />

                            <Grid Margin="0,10,0,0">
                                <ProgressBar x:Name="ProgressBar"
                                             Style="{StaticResource LauncherProgressBar}"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0" />
                                <TextBlock x:Name="ProgressPercentText"
                                           Text="0%"
                                           Foreground="#EAF6FF"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock x:Name="StatusText"
                                       Text="Inicializando..."
                                       Foreground="#DCEEFF"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="22,11,22,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SERVIDOR"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontSize="11"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="ManifestText"
                                       Foreground="#AABDD0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="16,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="enx-cirion-16.enx.host:10068"
                                       Foreground="#FFFFFF"
                                       FontSize="16"
                                       FontWeight="Bold" />
                            <Button Content="Copiar IP"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="86"
                                    Height="28"
                                    Padding="10,2"
                                    Margin="12,0,0,0"
                                    Click="CopyIpButton_Click" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Hospedado na Enxada Host"
                                       Foreground="#94A9B9"
                                       FontSize="12" />
                            <TextBlock x:Name="ServerPlayersText"
                                       Text="Online: consultando..."
                                       Foreground="{StaticResource CyanBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="360"
                                       Margin="14,0,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Width="330"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="PackSummaryText"
                                   Text="Manifest pendente"
                                   Foreground="#FFFFFF"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right" />
                        <TextBlock x:Name="RamText"
                                   Foreground="#94A9B9"
                                   FontSize="12"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button Content="Discord"
                                    Style="{StaticResource FooterLinkButton}"
                                    Click="DiscordButton_Click" />
                            <Button Content="Site"
                                    Style="{StaticResource FooterLinkButton}"
                                    Margin="10,0,0,0"
                                    Click="WebsiteButton_Click" />
                        </StackPanel>
                        <TextBox x:Name="LogTextBox"
                                 Height="32"
                                 Margin="0,7,0,0"
                                 Background="#66000000"
                                 BorderBrush="#304B68"
                                 Foreground="#AABDD0"
                                 FontFamily="Consolas"
                                 FontSize="10"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Disabled"
                                 Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
