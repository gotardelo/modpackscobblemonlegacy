<Window x:Class="CobblemonLegacy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobblemon Legacy Launcher"
        Width="1080"
        Height="680"
        MinWidth="960"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#08110D">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08110D" Offset="0" />
                <GradientStop Color="#102719" Offset="0.42" />
                <GradientStop Color="#272015" Offset="0.72" />
                <GradientStop Color="#10232C" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="COBBLEMON LEGACY"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="44"
                               FontWeight="Black" />
                    <TextBlock Text="Fabric 1.21.1"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="2,4,0,0" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,30,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border CornerRadius="8"
                            Padding="18"
                            Background="#D914241B"
                            BorderBrush="#36523D"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SERVIDOR"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontSize="12"
                                           FontWeight="Bold" />
                                <TextBlock Text="enx-cirion-16.enx.host:10068"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Margin="0,5,0,0" />
                                <TextBlock Text="Hospedado na Enxada Host"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="13"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Copiar IP"
                                    MinWidth="112"
                                    VerticalAlignment="Center"
                                    Click="CopyIpButton_Click" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            CornerRadius="8"
                            Padding="18"
                            Background="#C8111D17"
                            BorderBrush="#2E4937"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="Atividade"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           DockPanel.Dock="Left" />
                                <TextBlock x:Name="ManifestText"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Right"
                                           DockPanel.Dock="Right" />
                            </DockPanel>

                            <TextBox x:Name="LogTextBox"
                                     Grid.Row="1"
                                     Margin="0,14,0,0"
                                     Background="#B90A120E"
                                     BorderBrush="#284032"
                                     Foreground="{StaticResource MutedBrush}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Cobblemon Legacy"
                           Foreground="#789579"
                           FontSize="12" />
            </Grid>

            <Border Grid.Column="2"
                    CornerRadius="8"
                    Padding="22"
                    Background="#E1122019"
                    BorderBrush="#385544"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Conta"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="20"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="AccountText"
                                   Text="Carregando..."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Microsoft"
                                Click="MicrosoftModeButton_Click" />
                        <Button Grid.Column="2"
                                Content="Nickname"
                                Style="{StaticResource SecondaryButton}"
                                Click="OfflineModeButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Text="Nickname offline"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NicknameTextBox"
                                     MaxLength="16" />
                            <Button Grid.Column="2"
                                    Content="Salvar"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="88"
                                    Click="SaveNicknameButton_Click" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,28,0,0">
                        <Border CornerRadius="8"
                                Padding="16"
                                Background="#B91A2D22"
                                BorderBrush="#33523B"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Modpack"
                                           Foreground="{StaticResource GoldBrush}"
                                           FontWeight="Bold"
                                           FontSize="12" />
                                <TextBlock x:Name="PackSummaryText"
                                           Text="Manifest pendente"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Margin="0,6,0,0" />
                                <TextBlock x:Name="RamText"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="13"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <ProgressBar x:Name="ProgressBar"
                                     Height="10"
                                     Margin="0,18,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#203327" />

                        <TextBlock x:Name="StatusText"
                                   Text="Inicializando..."
                                   Foreground="{StaticResource MutedBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Margin="0,12,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button x:Name="PlayButton"
                                Content="Jogar"
                                Height="58"
                                FontSize="18"
                                Click="PlayButton_Click" />
                        <Button Grid.Row="2"
                                Content="Atualizar pack"
                                Style="{StaticResource SecondaryButton}"
                                Height="42"
                                Click="UpdateButton_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
