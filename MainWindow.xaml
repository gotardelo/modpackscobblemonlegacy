<Window x:Class="CobblemonLegacy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobblemon Legacy Launcher"
        Width="980"
        Height="552"
        MinWidth="980"
        MinHeight="552"
        MaxWidth="980"
        MaxHeight="552"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Icon="Assets/launcher-icon.ico"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="TitleShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.9" />
        <DropShadowEffect x:Key="LogoShadow"
                          Color="#00C8FF"
                          BlurRadius="10"
                          ShadowDepth="2"
                          Opacity="0.85" />

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>

        <Style x:Key="TopOptionsButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="86" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#EAFBFF" />
            <Setter Property="Background" Value="#7A071520" />
            <Setter Property="BorderBrush" Value="#6AD9F6" />
        </Style>

        <Style x:Key="TopUpdateButton" TargetType="Button" BasedOn="{StaticResource TopOptionsButton}">
            <Setter Property="Width" Value="126" />
            <Setter Property="Background" Value="#9A0A3A2F" />
            <Setter Property="BorderBrush" Value="#75FFD36A" />
        </Style>

        <Style x:Key="LoginOptionButton" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#F3FAFF" />
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonGlow"
                                    Margin="-2,0,-2,0"
                                    CornerRadius="8"
                                    Background="#123BFFE0"
                                    Opacity="0.16">
                                <Border.Effect>
                                    <DropShadowEffect Color="#46F2FF"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Opacity="0.65" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ButtonBase"
                                    Margin="0,5,0,0"
                                    CornerRadius="6"
                                    Background="#031119"
                                    Opacity="0.88" />
                            <Border x:Name="ButtonFace"
                                    Margin="0,0,0,5"
                                    CornerRadius="6"
                                    BorderBrush="#6F85F5FF"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#81111F2D" Offset="0" />
                                        <GradientStop Color="#A5081724" Offset="0.58" />
                                        <GradientStop Color="#7B062B35" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ClipToBounds="True">
                                    <Border Height="1"
                                            VerticalAlignment="Top"
                                            Margin="10,1,10,0"
                                            Background="#B8FFFFFF"
                                            Opacity="0.7" />
                                    <Border Width="6"
                                            HorizontalAlignment="Left"
                                            Opacity="0.92">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#8CFDFF" Offset="0" />
                                                <GradientStop Color="#41E8C2" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderBrush" Value="#C8FFFFFF" />
                                <Setter TargetName="ButtonBase" Property="Background" Value="#06435B" />
                                <Setter TargetName="ButtonGlow" Property="Opacity" Value="0.34" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,3,0,2" />
                                <Setter TargetName="ButtonBase" Property="Opacity" Value="0.55" />
                                <Setter TargetName="ButtonGlow" Property="Opacity" Value="0.2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Foreground" Value="#F3FEFF" />
            <Setter Property="FontFamily" Value="{StaticResource GameDisplayFont}" />
            <Setter Property="FontWeight" Value="ExtraBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonAura"
                                    Margin="-6,-5,-6,-2"
                                    CornerRadius="8"
                                    Background="#2148F5FF"
                                    Opacity="0.34">
                                <Border.Effect>
                                    <DropShadowEffect Color="#35E7FF"
                                                      BlurRadius="24"
                                                      ShadowDepth="0"
                                                      Opacity="0.78" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ButtonShadow"
                                    Margin="0,7,0,0"
                                    CornerRadius="7"
                                    Background="#010A10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#001D54"
                                                      BlurRadius="20"
                                                      ShadowDepth="4"
                                                      Opacity="0.9" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ButtonFace"
                                    Margin="0,0,0,7"
                                    CornerRadius="7"
                                    BorderBrush="#8DF1FF"
                                    BorderThickness="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#173A4D" Offset="0" />
                                        <GradientStop Color="#071925" Offset="0.5" />
                                        <GradientStop Color="#0B433B" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ClipToBounds="True">
                                    <Border Height="2"
                                            VerticalAlignment="Top"
                                            Margin="10,2,10,0"
                                            Background="#A9FFFFFF"
                                            Opacity="0.72" />
                                    <Border Width="120"
                                            HorizontalAlignment="Left"
                                            Opacity="0.24">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF5CFBFF" Offset="0" />
                                                <GradientStop Color="#5539F0C3" Offset="0.48" />
                                                <GradientStop Color="#0039F0C3" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderBrush" Value="#FFFFFF" />
                                <Setter TargetName="ButtonShadow" Property="Background" Value="#042D42" />
                                <Setter TargetName="ButtonAura" Property="Opacity" Value="0.62" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,5,0,2" />
                                <Setter TargetName="ButtonAura" Property="Opacity" Value="0.34" />
                                <Setter TargetName="ButtonShadow" Property="Opacity" Value="0.58" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterLinkButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EAFBFF" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonRoot">
                            <Border x:Name="ButtonBase"
                                    Margin="0,4,0,0"
                                    CornerRadius="5"
                                    Background="#01080E"
                                    Opacity="0.95" />
                            <Border x:Name="ButtonFace"
                                    Margin="0,0,0,4"
                                    CornerRadius="5"
                                    BorderBrush="#6DD9F6"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#2930485A" Offset="0" />
                                        <GradientStop Color="#68101D2A" Offset="0.54" />
                                        <GradientStop Color="#4B0C3E3A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ClipToBounds="True">
                                    <Border Height="1"
                                            VerticalAlignment="Top"
                                            Margin="6,1,6,0"
                                            Background="#E8FFFFFF"
                                            Opacity="0.38" />
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderBrush" Value="#FFFFFF" />
                                <Setter TargetName="ButtonBase" Property="Background" Value="#063845" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,3,0,1" />
                                <Setter TargetName="ButtonBase" Property="Margin" Value="0,4,0,0" />
                                <Setter TargetName="ButtonBase" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterUtilityButton" TargetType="Button" BasedOn="{StaticResource FooterLinkButton}">
            <Setter Property="Height" Value="29" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LauncherProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource CyanBrush}" />
            <Setter Property="Background" Value="#5B0A111A" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#526E95"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Margin="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#15A9FF" Offset="0" />
                                        <GradientStop Color="#64E8FF" Offset="0.55" />
                                        <GradientStop Color="#A8F1FF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="7"
            BorderBrush="#566472"
            BorderThickness="1"
            Background="#03070B"
            ClipToBounds="True">
        <Grid>
            <Image Source="Assets/launcher-hero-premium.png"
                   Stretch="UniformToFill"
                   Opacity="0.94" />

            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#AE000205" Offset="0" />
                        <GradientStop Color="#7B020814" Offset="0.45" />
                        <GradientStop Color="#5C05243B" Offset="0.72" />
                        <GradientStop Color="#9D000207" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <Rectangle Height="118"
                       VerticalAlignment="Top"
                       Fill="#AA000000"
                       IsHitTestVisible="False" />
            <Rectangle Height="90"
                       VerticalAlignment="Bottom"
                       Fill="#D0000000"
                       IsHitTestVisible="False" />

            <Grid MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="90" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Height="2"
                        VerticalAlignment="Bottom"
                        Background="#0366DA" />
                <Border Grid.Row="2"
                        Height="2"
                        VerticalAlignment="Top"
                        Background="#0366DA" />

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,4,0,0">
                    <TextBlock Text="COBBLEMON"
                               Foreground="#EAFEFF"
                               FontFamily="{StaticResource GameDisplayFont}"
                               FontSize="46"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Effect="{StaticResource LogoShadow}" />
                    <TextBlock Text="LEGACY"
                               Foreground="#9FF7FF"
                               FontFamily="{StaticResource GameDisplayFont}"
                               FontSize="37"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,-11,0,0"
                               Effect="{StaticResource TitleShadow}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,6,8,0">
                    <Button x:Name="UpdateLauncherButton"
                            Content="Atualizar"
                            Style="{StaticResource TopUpdateButton}"
                            Margin="0,0,8,0"
                            Visibility="Collapsed"
                            Click="UpdateLauncherButton_Click" />
                    <Button Content="Diagnostico"
                            Style="{StaticResource TopOptionsButton}"
                            Width="104"
                            Margin="0,0,8,0"
                            Click="DiagnosticsButton_Click" />
                    <Button Content="Verificar"
                            Style="{StaticResource TopOptionsButton}"
                            Width="92"
                            Margin="0,0,8,0"
                            Click="VerifyButton_Click" />
                    <Button Content="Opcoes"
                            Style="{StaticResource TopOptionsButton}"
                            Margin="0,0,8,0"
                            Click="OptionsButton_Click" />
                    <Button Content="–"
                            Style="{StaticResource ChromeButton}"
                            Click="MinimizeButton_Click" />
                    <Button Content="×"
                            Style="{StaticResource ChromeButton}"
                            Click="CloseButton_Click" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="430" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="NewsPanel"
                            Grid.Column="0"
                            Width="250"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"
                            Padding="14,12"
                            CornerRadius="7"
                            BorderBrush="#4A77A7C4"
                            BorderThickness="1"
                            Visibility="Collapsed">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#AD061018" Offset="0" />
                                <GradientStop Color="#D0091724" Offset="0.62" />
                                <GradientStop Color="#9A06303A" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="22"
                                              ShadowDepth="5"
                                              Opacity="0.58" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="AVISOS"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontSize="11"
                                       FontWeight="Black" />
                            <TextBlock x:Name="NewsTitleText"
                                       Foreground="#FFFFFF"
                                       FontSize="15"
                                       FontWeight="Black"
                                       Margin="0,5,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="NewsBodyText"
                                       Foreground="#C9DCE8"
                                       FontSize="12"
                                       LineHeight="15"
                                       Margin="0,5,0,8"
                                       MaxHeight="78"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="NewsAllButton"
                                        Content="Ver avisos"
                                        Height="28"
                                        Padding="10,0"
                                        Style="{StaticResource FooterUtilityButton}"
                                        Click="NewsAllButton_Click" />
                                <Button x:Name="NewsLinkButton"
                                        Content="Abrir link"
                                        Height="28"
                                        Padding="10,0"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource FooterUtilityButton}"
                                        Visibility="Collapsed"
                                        Click="NewsLinkButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Width="430"
                            VerticalAlignment="Center"
                            Padding="18,14"
                            CornerRadius="7"
                            BorderBrush="#3F6E91AF"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8A061018" Offset="0" />
                                <GradientStop Color="#A20A1724" Offset="0.52" />
                                <GradientStop Color="#76072C41" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="28"
                                              ShadowDepth="6"
                                              Opacity="0.66" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock x:Name="LoginTitleText"
                                       Text="Opcoes de Login"
                                       Foreground="#FFFFFF"
                                       FontFamily="{StaticResource GameDisplayFont}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Effect="{StaticResource TitleShadow}" />

                            <TextBlock x:Name="AccountText"
                                       Text="Carregando..."
                                       Foreground="#C6D8E8"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Margin="0,6,0,20"
                                       Visibility="Collapsed" />

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,18,0,0"
                                    Click="MicrosoftModeButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="22"
                                          Height="22"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Rectangle Fill="#F25022" />
                                        <Rectangle Grid.Column="1" Fill="#7FBA00" />
                                        <Rectangle Grid.Row="1" Fill="#00A4EF" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="Entrar com Microsoft"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,8,0,0"
                                    Click="OfflineModeButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="23"
                                            Height="23"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="#FFFFFF"
                                            BorderThickness="2"
                                            CornerRadius="4">
                                        <TextBlock Text="+"
                                                   Foreground="#FFFFFF"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-4,0,0" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Usar nickname offline"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Grid x:Name="NicknameEditorPanel"
                                  Margin="0,14,0,0"
                                  Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="94" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NicknameTextBox"
                                         MaxLength="16"
                                         ToolTip="Nickname offline" />
                                <Button Grid.Column="2"
                                        Content="Salvar"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="SaveNicknameButton_Click" />
                            </Grid>

                            <Button x:Name="PlayButton"
                                    Content="JOGAR"
                                    Height="52"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource PrimaryActionButton}"
                                    FontSize="22"
                                    FontWeight="ExtraBold"
                                    Visibility="Collapsed"
                                    Click="PlayButton_Click" />

                            <Grid Margin="0,10,0,0">
                                <ProgressBar x:Name="ProgressBar"
                                             Style="{StaticResource LauncherProgressBar}"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0" />
                                <TextBlock x:Name="ProgressPercentText"
                                           Text="0%"
                                           Foreground="#EAF6FF"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock x:Name="StatusText"
                                       Text="Inicializando..."
                                       Foreground="#DCEEFF"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                            <TextBlock x:Name="IntegrityText"
                                       Text="Integridade: aguardando..."
                                       Foreground="#8EDAF0"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="18,7,18,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="442" />
                    </Grid.ColumnDefinitions>

                    <Border CornerRadius="7"
                            BorderBrush="#4A77A7C4"
                            BorderThickness="1"
                            Padding="12,7">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#BA07111A" Offset="0" />
                                <GradientStop Color="#D1081724" Offset="0.58" />
                                <GradientStop Color="#BA041018" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="18"
                                              ShadowDepth="4"
                                              Opacity="0.55" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="17" />
                                <RowDefinition Height="29" />
                                <RowDefinition Height="15" />
                            </Grid.RowDefinitions>

                            <Border Height="1"
                                    VerticalAlignment="Top"
                                    Background="#68BDEBFF"
                                    Opacity="0.65" />

                            <Grid Grid.Row="0">
                                <TextBlock Text="SERVIDOR"
                                           Foreground="{StaticResource CyanBrush}"
                                           FontSize="11"
                                           FontWeight="Black"
                                           VerticalAlignment="Center" />
                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Padding="8,1"
                                        CornerRadius="5"
                                        Background="#3624E6FF"
                                        BorderBrush="#6A4BE7FF"
                                        BorderThickness="1">
                                    <TextBlock x:Name="ServerPlayersText"
                                               Text="Online: consultando..."
                                               Foreground="#72E7FF"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="250" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,1,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="9" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="enx-cirion-16.enx.host:10068"
                                           Foreground="#FFFFFF"
                                           FontSize="16"
                                           FontWeight="Black"
                                           VerticalAlignment="Center"
                                           Effect="{StaticResource TitleShadow}" />
                                <Button Grid.Column="2"
                                        Content="Copiar IP"
                                        Style="{StaticResource FooterUtilityButton}"
                                        Click="CopyIpButton_Click" />
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,1,0,0">
                                <TextBlock Text="Hospedado na Enxada Host"
                                           Foreground="#AFC2D2"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Padding="7,0"
                                        CornerRadius="4"
                                        Background="#2413A7FF"
                                        BorderBrush="#3662B7DD"
                                        BorderThickness="1">
                                    <TextBlock x:Name="ManifestText"
                                               Foreground="#D8F6FF"
                                               FontSize="10"
                                               FontWeight="Bold" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="7"
                            BorderBrush="#4A77A7C4"
                            BorderThickness="1"
                            Padding="12,7">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#BB08131D" Offset="0" />
                                <GradientStop Color="#DD091A26" Offset="0.55" />
                                <GradientStop Color="#B8041018" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#000000"
                                              BlurRadius="18"
                                              ShadowDepth="4"
                                              Opacity="0.55" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="17" />
                                <RowDefinition Height="33" />
                                <RowDefinition Height="11" />
                            </Grid.RowDefinitions>

                            <Border Height="1"
                                    VerticalAlignment="Top"
                                    Background="#68BDEBFF"
                                    Opacity="0.65" />

                            <TextBlock Text="COMUNIDADE"
                                       Foreground="{StaticResource CyanBrush}"
                                       FontSize="11"
                                       FontWeight="Black"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="PackSummaryText"
                                       Text="Manifest pendente"
                                       Foreground="#FFFFFF"
                                       FontSize="12"
                                       FontWeight="Black"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="205" />

                            <StackPanel Grid.Row="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="Opcoes"
                                        Width="78"
                                        MinWidth="0"
                                        Style="{StaticResource FooterLinkButton}"
                                        Click="OptionsButton_Click" />
                                <Button Content="Reparar"
                                        Width="78"
                                        MinWidth="0"
                                        Style="{StaticResource FooterLinkButton}"
                                        Margin="8,0,0,0"
                                        Click="RepairButton_Click" />
                                <Button Content="Relatorio"
                                        Width="78"
                                        MinWidth="0"
                                        Style="{StaticResource FooterLinkButton}"
                                        Margin="8,0,0,0"
                                        Click="CrashReportButton_Click" />
                                <Button Content="Discord"
                                        Width="78"
                                        MinWidth="0"
                                        Style="{StaticResource FooterLinkButton}"
                                        Margin="8,0,0,0"
                                        Click="DiscordButton_Click" />
                                <Button Content="Site"
                                        Width="78"
                                        MinWidth="0"
                                        Style="{StaticResource FooterLinkButton}"
                                        Margin="8,0,0,0"
                                        Click="WebsiteButton_Click" />
                            </StackPanel>

                            <TextBlock x:Name="RamText"
                                       Grid.Row="2"
                                       Foreground="#B6C9DA"
                                       FontSize="11"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom" />

                        <TextBox x:Name="LogTextBox"
                                  Height="32"
                                  Margin="0"
                                  Background="#66000000"
                                  BorderBrush="#304B68"
                                  Foreground="#AABDD0"
                                  FontFamily="Consolas"
                                  FontSize="10"
                                  IsReadOnly="True"
                                  TextWrapping="NoWrap"
                                  VerticalScrollBarVisibility="Disabled"
                                  Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
