<Application x:Class="CobblemonLegacy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#F3FAFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#AABDD0" />
        <SolidColorBrush x:Key="PanelBrush" Color="#071018" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#111A24" />
        <SolidColorBrush x:Key="AccentBrush" Color="#13A7FF" />
        <SolidColorBrush x:Key="GoldBrush" Color="#E0B35A" />
        <SolidColorBrush x:Key="CoralBrush" Color="#FF5F72" />
        <SolidColorBrush x:Key="CyanBrush" Color="#58D7FF" />
        <FontFamily x:Key="GameDisplayFont">pack://application:,,,/Assets/Fonts/#Oxanium</FontFamily>
        <FontFamily x:Key="GameUiFont">pack://application:,,,/Assets/Fonts/#Rajdhani</FontFamily>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#03101A" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="#6ED0FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonBase"
                                    Margin="0,4,0,0"
                                    Background="#021018"
                                    CornerRadius="5" />
                            <Border x:Name="ButtonFace"
                                    Margin="0,0,0,4"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,3,0,1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#7A071520" />
            <Setter Property="BorderBrush" Value="#5AA7D7EA" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource CyanBrush}" />
            <Setter Property="Background" Value="#A3070D12" />
            <Setter Property="BorderBrush" Value="#586A7F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
