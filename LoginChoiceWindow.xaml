<Window x:Class="CobblemonLegacy.LoginChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobblemon Legacy - Login"
        Width="720"
        Height="430"
        MinWidth="720"
        MinHeight="430"
        MaxWidth="720"
        MaxHeight="430"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Icon="Assets/launcher-icon.ico"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="TitleShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.9" />

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>

        <Style x:Key="LoginOptionButton" TargetType="Button">
            <Setter Property="Height" Value="58" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#F3FAFF" />
            <Setter Property="FontFamily" Value="{StaticResource GameUiFont}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ButtonGlow"
                                    Margin="-2,0,-2,0"
                                    CornerRadius="8"
                                    Background="#123BFFE0"
                                    Opacity="0.16">
                                <Border.Effect>
                                    <DropShadowEffect Color="#46F2FF"
                                                      BlurRadius="16"
                                                      ShadowDepth="0"
                                                      Opacity="0.65" />
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ButtonBase"
                                    Margin="0,5,0,0"
                                    CornerRadius="6"
                                    Background="#031119"
                                    Opacity="0.88" />
                            <Border x:Name="ButtonFace"
                                    Margin="0,0,0,5"
                                    CornerRadius="6"
                                    BorderBrush="#6F85F5FF"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#81111F2D" Offset="0" />
                                        <GradientStop Color="#A5081724" Offset="0.58" />
                                        <GradientStop Color="#7B062B35" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid ClipToBounds="True">
                                    <Border Width="6"
                                            HorizontalAlignment="Left"
                                            Opacity="0.92">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#8CFDFF" Offset="0" />
                                                <GradientStop Color="#41E8C2" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="BorderBrush" Value="#C8FFFFFF" />
                                <Setter TargetName="ButtonBase" Property="Background" Value="#06435B" />
                                <Setter TargetName="ButtonGlow" Property="Opacity" Value="0.34" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonFace" Property="Margin" Value="0,3,0,2" />
                                <Setter TargetName="ButtonBase" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="7"
            BorderBrush="#566472"
            BorderThickness="1"
            Background="#04080D"
            ClipToBounds="True">
        <Grid>
            <Image Source="Assets/launcher-hero-premium.png"
                   Stretch="UniformToFill"
                   Opacity="0.78" />
            <Rectangle Fill="#D9000206" />
            <Rectangle Height="104"
                       VerticalAlignment="Top"
                       Fill="#BA000000"
                       IsHitTestVisible="False" />
            <Rectangle Height="2"
                       VerticalAlignment="Top"
                       Margin="0,104,0,0"
                       Fill="#0366DA" />

            <Grid MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="104" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="54" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="COBBLEMON"
                               Foreground="#EAFEFF"
                               FontFamily="{StaticResource GameDisplayFont}"
                               FontSize="39"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Effect="{StaticResource TitleShadow}" />
                    <TextBlock Text="LEGACY"
                               Foreground="#9FF7FF"
                               FontFamily="{StaticResource GameDisplayFont}"
                               FontSize="31"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,-12,0,0"
                               Effect="{StaticResource TitleShadow}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,6,8,0">
                    <Button Content="–"
                            Style="{StaticResource ChromeButton}"
                            Click="MinimizeButton_Click" />
                    <Button Content="×"
                            Style="{StaticResource ChromeButton}"
                            Click="CloseButton_Click" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid x:Name="ChoicePanel"
                          Width="390"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Opções de Login"
                                       Foreground="#FFFFFF"
                                       FontFamily="{StaticResource GameDisplayFont}"
                                       FontSize="23"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       Effect="{StaticResource TitleShadow}" />
                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,24,0,0"
                                    Click="MicrosoftButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="22"
                                          Height="22"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Rectangle Fill="#F25022" />
                                        <Rectangle Grid.Column="1" Fill="#7FBA00" />
                                        <Rectangle Grid.Row="1" Fill="#00A4EF" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="Entrar com Microsoft"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,12,0,0"
                                    Click="OfflineButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="23"
                                            Height="23"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="#FFFFFF"
                                            BorderThickness="2"
                                            CornerRadius="4">
                                        <TextBlock Text="+"
                                                   Foreground="#FFFFFF"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-4,0,0" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Usar nickname offline"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="NicknamePanel"
                                Width="390"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Digite seu nickname"
                                   Foreground="#FFFFFF"
                                   FontFamily="{StaticResource GameDisplayFont}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Effect="{StaticResource TitleShadow}" />
                        <TextBox x:Name="NicknameTextBox"
                                 Margin="0,22,0,0"
                                 MaxLength="16" />
                        <TextBlock x:Name="NicknameErrorText"
                                   Foreground="{StaticResource CoralBrush}"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="128" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Salvar nickname"
                                    Click="SaveNicknameButton_Click" />
                            <Button Grid.Column="2"
                                    Content="Voltar"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BackButton_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Servidor: enx-cirion-16.enx.host:10068"
                           Foreground="#C6D8E8"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
