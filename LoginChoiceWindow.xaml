<Window x:Class="CobblemonLegacy.LoginChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobblemon Legacy - Login"
        Width="720"
        Height="430"
        MinWidth="720"
        MinHeight="430"
        MaxWidth="720"
        MaxHeight="430"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <DropShadowEffect x:Key="TitleShadow"
                          Color="#000000"
                          BlurRadius="18"
                          ShadowDepth="2"
                          Opacity="0.9" />

        <Style x:Key="ChromeButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#EAF6FF" />
            <Setter Property="Background" Value="#22000000" />
            <Setter Property="BorderBrush" Value="#00000000" />
        </Style>

        <Style x:Key="LoginOptionButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="58" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#F3FAFF" />
            <Setter Property="Background" Value="#36070D12" />
            <Setter Property="BorderBrush" Value="#7C7892A6" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="7"
            BorderBrush="#566472"
            BorderThickness="1"
            Background="#04080D"
            ClipToBounds="True">
        <Grid>
            <Image Source="Assets/launcher-hero.png"
                   Stretch="UniformToFill"
                   Opacity="0.7" />
            <Rectangle Fill="#D9000206" />
            <Rectangle Height="104"
                       VerticalAlignment="Top"
                       Fill="#BA000000"
                       IsHitTestVisible="False" />
            <Rectangle Height="2"
                       VerticalAlignment="Top"
                       Margin="0,104,0,0"
                       Fill="#0366DA" />

            <Grid MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="104" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="54" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="COBBLEMON"
                               Foreground="#D7D9DA"
                               FontFamily="Segoe UI Black"
                               FontSize="38"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Effect="{StaticResource TitleShadow}" />
                    <TextBlock Text="LEGACY"
                               Foreground="#F1F3F4"
                               FontFamily="Segoe UI Black"
                               FontSize="31"
                               FontWeight="Black"
                               TextAlignment="Center"
                               Margin="0,-12,0,0"
                               Effect="{StaticResource TitleShadow}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,6,8,0">
                    <Button Content="–"
                            Style="{StaticResource ChromeButton}"
                            Click="MinimizeButton_Click" />
                    <Button Content="×"
                            Style="{StaticResource ChromeButton}"
                            Click="CloseButton_Click" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid x:Name="ChoicePanel"
                          Width="390"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Opções de Login"
                                       Foreground="#FFFFFF"
                                       FontSize="25"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Effect="{StaticResource TitleShadow}" />
                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,24,0,0"
                                    Click="MicrosoftButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="22"
                                          Height="22"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Rectangle Fill="#F25022" />
                                        <Rectangle Grid.Column="1" Fill="#7FBA00" />
                                        <Rectangle Grid.Row="1" Fill="#00A4EF" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" />
                                    </Grid>
                                    <TextBlock Grid.Column="1"
                                               Text="Entrar com Microsoft"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource LoginOptionButton}"
                                    Margin="0,12,0,0"
                                    Click="OfflineButton_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="23"
                                            Height="23"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="#FFFFFF"
                                            BorderThickness="2"
                                            CornerRadius="4">
                                        <TextBlock Text="+"
                                                   Foreground="#FFFFFF"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-4,0,0" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="Usar nickname offline"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="NicknamePanel"
                                Width="390"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Digite seu nickname"
                                   Foreground="#FFFFFF"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Effect="{StaticResource TitleShadow}" />
                        <TextBox x:Name="NicknameTextBox"
                                 Margin="0,22,0,0"
                                 MaxLength="16" />
                        <TextBlock x:Name="NicknameErrorText"
                                   Foreground="{StaticResource CoralBrush}"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="128" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Salvar nickname"
                                    Click="SaveNicknameButton_Click" />
                            <Button Grid.Column="2"
                                    Content="Voltar"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BackButton_Click" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Servidor: enx-cirion-16.enx.host:10068"
                           Foreground="#C6D8E8"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
