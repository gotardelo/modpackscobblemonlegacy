<Window x:Class="CobblemonLegacy.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostico"
        Width="720"
        Height="620"
        MinWidth="660"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="Assets/launcher-icon.ico">
    <Window.Resources>
        <DropShadowEffect x:Key="PanelShadow"
                          Color="#000000"
                          BlurRadius="28"
                          ShadowDepth="8"
                          Opacity="0.78" />

        <Style x:Key="DiagnosticButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="#F3FAFF" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="8"
            BorderBrush="#5A88A8BE"
            BorderThickness="1"
            Background="#F0050B11"
            Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#11162128" Offset="0" />
                        <GradientStop Color="#12264554" Offset="0.58" />
                        <GradientStop Color="#100B141B" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,0,10,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Diagnostico"
                                   Foreground="#FFFFFF"
                                   FontFamily="{StaticResource GameDisplayFont}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock x:Name="GeneratedAtText"
                                   Foreground="{StaticResource CyanBrush}"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </StackPanel>
                    <Button Content="X"
                            Width="34"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryButton}"
                            Padding="0"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,18,24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Use esta tela para conferir o estado do launcher antes de chamar suporte."
                           Foreground="#C9DCE8"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <DataGrid x:Name="DiagnosticsGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          RowBackground="#56081118"
                          AlternatingRowBackground="#680C1721"
                          Background="#78050B11"
                          BorderBrush="#345A7890"
                          BorderThickness="1"
                          Foreground="#F3FAFF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding State}"
                                            Width="86" />
                        <DataGridTextColumn Header="Item"
                                            Binding="{Binding Name}"
                                            Width="170" />
                        <DataGridTextColumn Header="Valor"
                                            Binding="{Binding Value}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="#223D536A"
                    BorderThickness="0,1,0,0"
                    Background="#F2070D12">
                <Grid Margin="24,0">
                    <TextBlock x:Name="StatusText"
                               Foreground="#AFC2D2"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Copiar"
                                Style="{StaticResource DiagnosticButton}"
                                Click="CopyButton_Click" />
                        <Button Content="Gerar ZIP"
                                Style="{StaticResource DiagnosticButton}"
                                Margin="10,0,0,0"
                                Click="CreatePackageButton_Click" />
                        <Button Content="Discord"
                                Style="{StaticResource DiagnosticButton}"
                                Margin="10,0,0,0"
                                Click="DiscordButton_Click" />
                        <Button Content="Fechar"
                                Style="{StaticResource DiagnosticButton}"
                                Margin="10,0,0,0"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
